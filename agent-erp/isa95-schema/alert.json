{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ISA-95 Alarm -> Agent Alert",
  "description": "Alarma mapeada desde el objeto Event/Alarm de ISA-95",
  "type": "object",
  "required": ["alert_id", "severity", "source_level"],
  "properties": {
    "alert_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "critical", "emergency"]
    },
    "source_level": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"],
      "description": "Nivel ISA-95 donde se origino la alarma"
    },
    "source_id": {
      "type": "string",
      "description": "ID del agente, equipo o proceso que genero la alarma"
    },
    "category": {
      "type": "string",
      "enum": ["offline", "budget_exceeded", "error_spike", "latency_high", "memory_full", "security", "quality_fail", "maintenance_due"]
    },
    "message": {
      "type": "string"
    },
    "details": {
      "type": "object",
      "description": "Datos adicionales de contexto"
    },
    "triggered_at": {
      "type": "string",
      "format": "date-time"
    },
    "acknowledged": {
      "type": "boolean",
      "default": false
    },
    "acknowledged_by": {
      "type": "string"
    },
    "escalation_level": {
      "type": "integer",
      "default": 0,
      "description": "Nivel de escalamiento (0=no escalado)"
    },
    "actions_taken": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "result": { "type": "string" }
        }
      }
    }
  }
}