{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ISA-95 Material -> Skill / Memory / Data",
  "description": "Skill, memoria o dato mapeado desde el objeto Material de ISA-95",
  "type": "object",
  "required": ["material_id", "material_class"],
  "properties": {
    "material_id": {
      "type": "string",
      "description": "Identificador del skill o memoria (skill-building-v2, memory-eko-001, etc.)"
    },
    "material_class": {
      "type": "string",
      "enum": ["procedural_skill", "narrative_skill", "config", "data", "prompt_template", "model_weights", "embedding_store"],
      "description": "Tipo de material"
    },
    "material_name": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "description": "Proposito y uso del material"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Otros materiales requeridos"
    },
    "used_by": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Agentes que cargan o usan este material"
    },
    "location": {
      "type": "string",
      "description": "Ruta o URL donde reside"
    },
    "checksum": {
      "type": "string",
      "description": "Hash de integridad"
    },
    "size_bytes": {
      "type": "integer"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "draft", "archived"]
    }
  }
}
