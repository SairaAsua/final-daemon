      "responsible_objects": ["task-queue.db", "workflow-engine", "backend-apis", "autoresearch-pipeline"]
    },
    "H8": {
      "name": "Jeremias",
      "role": "Infra, Security, Observability",
      "levels": ["L2"],
      "scope": "SCADA/HMI + infraestructura fisica",
      "accountable_for": ["Dashboards", "Alerting", "Infra", "Security hardening", "Uptime"],
      "responsible_objects": ["isa95-dashboard", "alert-system", "infra-as-code", "security-policies"]
    }
  }
}
