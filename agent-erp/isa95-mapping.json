      "levels": ["L4", "L3", "L1", "L0"],
      "scope": "Transversal — calidad psicologica de agentes",
      "accountable_for": ["Human Design profiles", "SOUL coherence", "Demo validation", "Shadow/light mapping"],
      "responsible_objects": ["SOUL.md templates", "HD profiles", "demo-scripts"]
    },
    "H5": {
