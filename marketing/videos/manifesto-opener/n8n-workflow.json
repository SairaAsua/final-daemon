    },
    "Loop · one shot at a time": {
      "main": [
        [{ "node": "Write concat.txt", "type": "main", "index": 0 }],
        [{ "node": "Nano Banana Pro · generate frame", "type": "main", "index": 0 }]
      ]
    },
    "Nano Banana Pro · generate frame": {
      "main": [[{ "node": "Extract image binary", "type": "main", "index": 0 }]]
    },
    "Extract image binary": {
      "main": [[{ "node": "Save frame PNG", "type": "main", "index": 0 }]]
    },
    "Save frame PNG": {
      "main": [[{ "node": "Veo 3.1 · start video job", "type": "main", "index": 0 }]]
    },
    "Veo 3.1 · start video job": {
      "main": [[{ "node": "Wait 20s", "type": "main", "index": 0 }]]
    },
