    },
    "Done?": {
      "main": [
        [{ "node": "Extract video URI", "type": "main", "index": 0 }],
        [{ "node": "Wait 20s", "type": "main", "index": 0 }]
      ]
    },
    "Extract video URI": {
      "main": [[{ "node": "Download video", "type": "main", "index": 0 }]]
    },
    "Download video": {
      "main": [[{ "node": "Save clip MP4", "type": "main", "index": 0 }]]
    },
    "Save clip MP4": {
      "main": [[{ "node": "Loop · one shot at a time", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false
}
